#!/bin/sh

# --- Configuration ---
MODPATH="/data/adb/modules/Lynx"
SCRIPT_DIR="$MODPATH/script"
LIB_DIR="$SCRIPT_DIR/lib"
LOG_FILE="/storage/emulated/0/Lynx/Lynx.log"

# --- Utility Functions ---

# Unified logging function
log_msg() {
    local type="$1"
    local message="$2"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    local formatted_msg="[$timestamp] [$type] $message"
    
    # Print to console with colors if possible
    case "$type" in
        INFO)  echo -e "\e[1;32m[INFO]\e[0m $message" ;;
        ERROR) echo -e "\e[1;31m[ERROR]\e[0m $message" ;;
        WARN)  echo -e "\e[1;33m[WARN]\e[0m $message" ;;
        *)     echo "[$type] $message" ;;
    esac
    
    # Append to log file
    echo "$formatted_msg" >> "$LOG_FILE"
}

# Error exit helper
error_exit() {
    log_msg "ERROR" "$1"
    exit 1
}

# Safe library loader
load_lib() {
    local lib_name="$1"
    local lib_path="$LIB_DIR/$lib_name.sh"

    if [ ! -d "$LIB_DIR" ]; then
        error_exit "Library directory not found at $LIB_DIR"
    fi

    if [ -f "$lib_path" ]; then
        . "$lib_path"
    else
        error_exit "Library '$lib_name' not found at $lib_path"
    fi
}

# Generic command dispatcher for standard help/apply pattern
dispatch_standard() {
    local cmd_name="$1"
    local sub_cmd="$2"
    local apply_func="$3"
    
    load_lib "$cmd_name"
    
    case "$sub_cmd" in
        help)
            local help_func="help_${cmd_name}"
            if type "$help_func" >/dev/null 2>&1; then
                "$help_func"
            else
                log_msg "WARN" "No specific help found for $cmd_name."
            fi
            ;;
        apply)
            if type "$apply_func" >/dev/null 2>&1; then
                "$apply_func"
            else
                error_exit "Apply function '$apply_func' not found in $cmd_name library."
            fi
            ;;
        *)
            error_exit "Invalid sub-command '$sub_cmd' for -$cmd_name. Use 'Lxcore -$cmd_name help' for usage."
            ;;
    esac
}

# --- Main Logic ---

# Check if no arguments are provided
if [ $# -eq 0 ]; then
    load_lib "help"
    help
    exit 0
fi

COMMAND="$1"
shift # Move to the next argument

case "$COMMAND" in
    -help)
        load_lib "help"
        help
        ;;
    -ram)      dispatch_standard "ram" "$1" "main_ramv2" ;;
    -gpu)      dispatch_standard "gpu" "$1" "main_gpu" ;;
    -cpu)      dispatch_standard "cpu" "$1" "main_cpu" ;;
    -system)   dispatch_standard "system" "$1" "main_system" ;;
    -cache)    dispatch_standard "cache" "$1" "main_cache" ;;
    -task)     dispatch_standard "task" "$1" "main_task" ;;
    -unity)    dispatch_standard "unity" "$1" "main_unity" ;;
    -dex2oat)  dispatch_standard "dex2oat" "$1" "dex2oat_opt_enable" ;;
    
    -net)
        load_lib "net"
        main_net_command "$@"
        ;;
    -deepsleep)
        load_lib "deepsleep"
        if [ "$1" = "help" ]; then
            help_deepsleep
        else
            main_deepsleep "$1"
        fi
        ;;
    -gms)
        load_lib "gms"
        if [ "$1" = "help" ]; then
            help_gms
        else
            main_gms "$@"
        fi
        ;;
    -sqlite)
        load_lib "sqlite"
        if [ "$1" = "help" ] || [ -z "$1" ]; then
            help_sqlite
        else
            main_sqlite "$1"
        fi
        ;;
    -updater)
        load_lib "updater"
        if [ "$1" = "help" ]; then
            help_updater
        elif [ -n "$1" ]; then
            error_exit "Invalid argument for -updater. Use 'Lxcore -updater help' or just 'Lxcore -updater'."
        else
            main_updater
        fi
        ;;
    -zram)
        load_lib "zram"
        case "$1" in
            set)
                shift
                if [ "$1" = "help" ]; then
                    help_zram
                elif [[ "$1" == size=* || "$1" == algo=* ]]; then
                    main_setzram "$@"
                else
                    error_exit "Invalid arguments for -zram set. Use 'Lxcore -zram help' for usage."
                fi
                ;;
            disable) main_disablezram ;;
            help)    help_zram ;;
            *)       error_exit "Unknown option '$1' for -zram. Use 'Lxcore -zram help' for usage." ;;
        esac
        ;;
    -swap)
        load_lib "swap"
        case "$1" in
            help)    help_swap ;;
            set)
                shift
                if [[ "$1" == size=* ]]; then
                    size="${1#*=}"
                    main_setswap "$size"
                else
                    error_exit "Invalid arguments for -swap set. Use 'Lxcore -swap help' for usage."
                fi
                ;;
            enable)  main_enableswap ;;
            disable) main_disableswap ;;
            remove)  main_removeswap ;;
            *)       error_exit "Unknown option '$1' for -swap. Use 'Lxcore -swap help' for usage." ;;
        esac
        ;;
    -dns)
        load_lib "dns"
        if [ "$1" = "help" ]; then
            help_dns
        else
            main_dns "$1"
        fi
        ;;
    -io)
        load_lib "io"
        main_io "$@"
        ;;
    *)
        error_exit "Unknown command '$COMMAND'. Use 'Lxcore -help' for usage."
        ;;
esac
