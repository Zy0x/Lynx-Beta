                                flet_selected=$((num_flet_options - 1))
                            fi
                            show_flet_menu
                            ;;
                        B) # Panah bawah
                            if [ $flet_selected -lt $((num_flet_options - 1)) ]; then
                                flet_selected=$((flet_selected + 1))
                            else
                                flet_selected=0
                            fi
                            show_flet_menu
                            ;;
                        C) # Panah Kanan
                            if [ $flet_selected -lt $((num_flet_options - 1)) ]; then
                                flet_selected=$((flet_selected + 1))
                            else
                                flet_selected=0
                            fi
                            show_flet_menu
                            ;;
                        D) # Panah Kiri
                            if [ $flet_selected -gt 0 ]; then
                                flet_selected=$((flet_selected - 1))
                            else
                                flet_selected=$((num_flet_options - 1))
                            fi
                            show_flet_menu
                            ;;
                        H) # Tombol Home
                            flet_selected=0
                            selected=0
                            show_menu
                            break
                            ;;
                        F) # Tombol End
                            echo -e "\033[1A" # Pindah ke baris sebelumnya
                            echo -e "\033[K"  # Hapus seluruh baris
                            echo -e "\033[31mExit Lynx!\033[0m"
                            sleep 1.25
                            clear
                            exit
                            ;;
                        $'\x7f') # Tombol backspace (hapus)
                            if [ $flet_selected -eq 0 ]; then
                                selected=0
                                show_menu
                                break
                            else
                                flet_selected=0
                                show_flet_menu
                            fi
                            ;;
                        "") # Enter
                            if [ $flet_selected -eq 0 ]; then
                                clear
                                file_path="/storage/emulated/0/Lynx/applist_flow.conf"
                                if [ -f "$file_path" ]; then
                                    echo ""
                                    echo "List App Flow: "
                                    echo ""
                                    awk 'NF && $0 !~ /^ *#/' "$file_path" |
                                    sed 's/[^[:print:]]//g' |
                                    LC_ALL=C sort -f |
                                    awk '{print NR ". " $0}' |
                                    sed 's/^/\e[34m/' |
                                    sed 's/$/\e[0m/'
                                    echo ""
                                    echo -e "\e[36mDo you want to find an application? [yes/no] \e[0m"
                                    while true; do
                                        read input
                                        input=$(echo "$input" | tr '[:upper:]' '[:lower:]')
                                        if [ "$input" = "y" ] || [ "$input" = "yes" ]; then
                                            echo -e "\e[36mEnter PACKAGE NAME APP to search: \e[0m"
                                            read app_name
                                            search_result=$(grep -iF "$app_name" "$file_path" | awk '{print $1}')
                                            if [ -n "$search_result" ]; then
                                                clear
                                                echo -e "\e[32mSearch results for application '$app_name':\e[0m"
                                                echo "$search_result"
                                                echo ""
                                                echo -e "\e[34m Press backspace to return! \e[0m"
                                                # Baca Input
                                                while true; do
                                                    read -rsn1 list_input
                                                    case $list_input in
                                                        $'\x7f') # Tombol backspace (hapus)
                                                            flet_selected=0
                                                            show_perf_menu
                                                            break
                                                            ;;
                                                        *)
                                                            ;;
                                                    esac
                                                done
                                            else
                                                echo -e "\e[31mNo matching application found for '$app_name'.\e[0m"
                                                flet_selected=0
                                                sleep 2
                                                show_flet_menu
                                            fi
                                            break
                                        elif [ "$input" = "n" ] || [ "$input" = "no" ]; then
                                            clear
                                            flet_selected=0
                                            show_flet_menu
                                            break
                                        else
                                            echo "Invalid input. Please enter 'yes' or 'no'."
                                            sleep 1.5
                                            printf "\033[A\033[K\033[A\033[K"
                                        fi
                                    done
                                else
                                    echo -e "\e[31mFile can't read or not found!\e[0m"
                                    echo -e "\e[31mPlease reinstall module or directly add the application.\e[0m"
                                    sleep 2
                                    flet_selected=0
                                    selected=0
                                    show_menu
                                    break
                                fi
                            elif [ $flet_selected -eq 1 ]; then
                                echo -e "\e[34m  Add Application \e[0m"
                                echo "  (ex: com.miHoYo.GenshinImpact) "
                                echo ""
                                echo "  ~enter blank text to cancel~"
                                echo -e "\e[36m  Package Name: \e[0m\c"
                                read input
                                if [ -z "$input" ]; then
                                    clear
                                    flet_selected=0
                                    show_flet_menu
                                else
                                    file="/storage/emulated/0/Lynx/applist_flow.conf"
                                    if [ ! -f "$file" ]; then
                                        echo ""
                                        echo -e "\e[31m  File not found. Creating a new file...\e[0m"
                                        echo ""
                                        sleep 2
                                        touch "$file" 
                                    fi
                                    if ! grep -q "^$input$" /storage/emulated/0/Lynx/applist_flow.conf; then
                                        echo "$input" >> /storage/emulated/0/Lynx/applist_flow.conf
                                        echo "  $input added successfully!"
                                    else
                                        echo "  $input it's already on the list!."
                                    fi
                                    sleep 1.5
                                    clear
                                    flet_selected=0
                                    show_flet_menu
                                fi
                            elif [ $flet_selected -eq 2 ]; then
                                file="/storage/emulated/0/Lynx/applist_flow.conf"
                                if [ -f "$file_path" ]; then
                                    echo -e "\e[34m  Remove Application \e[0m"
                                    echo "  (ex: com.miHoYo.GenshinImpact) "
                                    echo ""
                                    echo "  ~enter blank text to cancel~"
                                    echo -e "\e[36m  Package Name: \e[0m\c"
                                    read input
                                    if [ -z "$input" ]; then
                                        clear
                                        flet_selected=0
                                        show_flet_menu
                                    else
                                        file="/storage/emulated/0/Lynx/applist_flow.conf"
                                        matches=$(grep -nix "$input" "$file" | cut -d ":" -f 1)
                                        if [ -n "$matches" ]; then
                                            sed -i "$(echo "${matches}" | sed 's/$/d/' | tr '\n' ',' | sed 's/,$//')" "$file"
                                            echo "  $input removed successfully!"
                                            sleep 1.25
                                            clear
                                            flet_selected=0
                                            show_flet_menu
                                        else
                                            echo "  No matches for: $input"
                                            sleep 1.5
                                            clear
                                            flet_selected=0
                                            show_flet_menu
                                        fi
                                    fi
                                else
                                    echo -e "\e[31mFile can't read or not found!\e[0m"
                                    echo -e "\e[31mPlease reinstall module or directly add the application.\e[0m"
                                    sleep 2
                                    flet_selected=0
                                    selected=0
                                    show_menu
                                    break
                                fi
                            elif [ $flet_selected -eq $((num_flet_options - 1)) ]; then
                                selected=0
                                flet_selected=0
                                show_menu
                                break
                            fi
                            ;;
                    esac
                done
            elif [ $selected -eq 5 ]; then
                show_misc_menu
                # Membaca input untuk Misc
                while true; do
                    read -rsn1 misc_input
                    case $misc_input in
                        A) # Panah atas
                            if [ $misc_selected -gt 0 ]; then
                                misc_selected=$((misc_selected - 1))
                            else
                                misc_selected=$((num_misc_options - 1))
                            fi
                            show_misc_menu
                            ;;
                        B) # Panah bawah
                            if [ $misc_selected -lt $((num_misc_options - 1)) ]; then
                                misc_selected=$((misc_selected + 1))
                            else
                                misc_selected=0
                            fi
                            show_misc_menu
                            ;;
                        C) # Panah Kanan
                            if [ $misc_selected -lt $((num_misc_options - 1)) ]; then
                                misc_selected=$((misc_selected + 1))
                            else
                                misc_selected=0
                            fi
                            show_misc_menu
                            ;;
                        D) # Panah Kiri
                            if [ $misc_selected -gt 0 ]; then
                                misc_selected=$((misc_selected - 1))
                            else
                                misc_selected=$((num_misc_options - 1))
                            fi
                            show_misc_menu
                            ;;
                        H) # Tombol Home
                            misc_selected=0
                            selected=0
                            show_menu
                            break
                            ;;
                        F) # Tombol End
                            echo -e "\033[1A" # Pindah ke baris sebelumnya
                            echo -e "\033[K"  # Hapus seluruh baris
                            echo -e "\033[31mExit Lynx!\033[0m"
                            sleep 1.25
                            clear
                            exit
                            ;;
                        $'\x7f') # Tombol backspace (hapus)
                            if [ $misc_selected -eq 0 ]; then
                                selected=0
                                show_menu
                                break
                            else
                                misc_selected=0
                                show_misc_menu
                            fi
                            ;;
                        "") # Enter
                            if [ $misc_selected -eq 0 ]; then
                                clear
                                gpu_cache="/data/adb/modules/Lynx/script/misc/gpu_cache_cleaner.sh"
                                if [ -f "$gpu_cache" ]; then
                                    echo "Please Wait..."
                                    sleep 2
                                    sh $gpu_cache
                                    misc_selected=0
                                    selected=0
                                    pkill -9 termux && break || exit
                                else
                                    echo -e "\e[31mFile can't read or not found!\e[0m"
                                    echo -e "\e[31mPlease reinstall module!\e[0m"
                                    sleep 2
                                    clear
                                    misc_selected=0
                                    selected=0
                                    show_misc_menu
                                fi
                            elif [ $misc_selected -eq 1 ]; then
                                clear
                                g_fixer="/data/adb/modules/Lynx/script/misc/g_fixer.sh"
                                if [ -f "$g_fixer" ]; then
                                    echo "Please Wait..."
                                    sleep 2
                                    sh $g_fixer
                                    misc_selected=0
                                    selected=0
                                    pkill -9 termux && break || exit
                                else
                                    echo -e "\e[31mFile can't read or not found!\e[0m"
                                    echo -e "\e[31mPlease reinstall module or directly add the application.\e[0m"
                                    sleep 2
                                    clear
                                    misc_selected=0
                                    selected=0
                                    show_misc_menu
                                fi
                            elif [ $misc_selected -eq 2 ]; then
                                clear
                                show_gi_menu
                                # Membaca input untuk submenu AutoCut Charging
                                while true; do
                                read -rsn1 gi_input
                                case $gi_input in
                                    A) # Panah atas
                                        if [ $gi_selected -gt 0 ]; then
                                            gi_selected=$((gi_selected - 1))
                                        else
                                            gi_selected=$((num_gi_options - 1))
                                        fi
                                        show_gi_menu
                                        ;;
                                    B) # Panah bawah
                                        if [ $gi_selected -lt $((num_gi_options - 1)) ]; then
                                            gi_selected=$((gi_selected + 1))
                                        else
                                            gi_selected=0
                                        fi
                                        show_gi_menu
                                        ;;
                                    C) # Panah Kanan
                                        if [ $gi_selected -lt $((num_gi_options - 1)) ]; then
                                            gi_selected=$((gi_selected + 1))
                                        else
                                            gi_selected=0
                                        fi
                                        show_gi_menu
                                        ;;
                                    D) # Panah Kiri
                                        if [ $gi_selected -gt 0 ]; then
                                            gi_selected=$((gi_selected - 1))
                                        else
                                            gi_selected=$((num_gi_options - 1))
                                        fi
                                        show_gi_menu
                                        ;;
                                    H) # Tombol Home
                                        gi_selected=0
                                        show_menu
                                        break
                                        ;;
                                    F) # Tombol End
                                        echo -e "\033[1A" # Pindah ke baris sebelumnya
                                        echo -e "\033[K"  # Hapus seluruh baris
                                        echo -e "\033[31mExit Lynx!\033[0m"
                                        sleep 1.25
                                        clear
                                        exit
                                        ;;
                                    $'\x7f') # Tombol backspace (hapus)
                                        if [ $gi_selected -eq 0 ]; then
                                            misc_selected=0
                                            show_misc_menu
                                            break
                                        else
                                            gi_selected=0
                                            show_gi_menu
                                        fi
                                        ;;
                                    "") # Enter
                                        if [ $gi_selected -eq 0 ]; then
                                            gl="/data/adb/modules/Lynx/script/misc/GI_GL.sh"
                                            if [ -f $gl ]; then
                                                echo "Please Wait..."
                                                sleep 2
                                                sh $gl
                                                gi_selected=0
                                                misc_selected=0
                                                pkill -9 termux && break || exit
                                            else
                                                echo -e "\e[31mFile can't read or not found!\e[0m"
                                                echo -e "\e[31mPlease reinstall module or directly add the application.\e[0m"
                                                sleep 2
                                                clear
                                                misc_selected=0
                                                gi_selected=0
                                                selected=0
                                                show_misc_menu
                                                break
                                            fi
                                        elif [ $gi_selected -eq 1 ]; then
                                            gl="/data/adb/modules/Lynx/script/misc/GI_VK.sh"
                                            if [ -f $gl ]; then
                                                echo "Please Wait..."
                                                sleep 2
                                                sh $gl
                                                gi_selected=0
                                                misc_selected=0
                                                pkill -9 termux && break || exit
                                            else
                                                echo -e "\e[31mFile can't read or not found!\e[0m"
                                                echo -e "\e[31mPlease reinstall module or directly add the application.\e[0m"
                                                sleep 2
                                                clear
                                                misc_selected=0
                                                gi_selected=0
                                                selected=0
                                                show_misc_menu
                                                break
                                            fi
                                        elif [ $gi_selected -eq $((num_gi_options - 1)) ]; then
                                            clear
                                            misc_selected=0
                                            gi_selected=0
                                            show_misc_menu
                                            break
                                        fi
                                    esac
                                done
                            elif [ $misc_selected -eq 3 ]; then
                                clear
                                clean="/data/adb/modules/Lynx/script/flow/flow5.sh"
                                if [ -f "$clean" ]; then
                                    echo "Please Wait..."
                                    sleep 2
                                    sh $clean
                                    misc_selected=0
                                    selected=0
                                    pkill -9 termux && break || exit
                                else
                                    echo -e "\e[31mFile can't read or not found!\e[0m"
                                    echo -e "\e[31mPlease reinstall module or directly add the application.\e[0m"
                                    sleep 2
                                    clear
                                    misc_selected=0
                                    selected=0
                                    show_misc_menu
                                fi
                             elif [ $misc_selected -eq 4 ]; then
                                clear
                                dex="/data/adb/modules/Lynx/script/misc/Dexoptimizer.sh"
                                if [ -f "$dex" ]; then
                                    echo "Please Wait..."
                                    sleep 2
                                    sh $dex
                                    misc_selected=0
                                    selected=0
                                    pkill -9 termux && break || exit
                                else
                                    echo -e "\e[31mFile can't read or not found!\e[0m"
                                    echo -e "\e[31mPlease reinstall module or directly add the application.\e[0m"
                                    sleep 2
                                    clear
                                    misc_selected=0
                                    selected=0
                                    show_misc_menu
                                fi
                            elif [ $misc_selected -eq $((num_misc_options - 1)) ]; then
                                selected=0
                                misc_selected=0
                                clear
                                show_menu
                                break
                            fi
                            ;;
                    esac
                done
            elif [ $selected -eq 6 ]; then
                if [ -d "/data/adb/modules/Lynx/" ]; then
                    show_info
                    # missing property messages
                    error_messages=""
                    
                    # Check Charging Control
                    charging_control=$(su -c getprop lynx.cc 2>/dev/null)
                    if [ -z "$charging_control" ]; then
                        error_messages+="Charging Control           : Property not found\n"
                    else
                        if [ "$charging_control" -eq 1 ]; then
                            echo -e "\e[32mCharging Control           : Active\e[0m"
                        else
                            echo -e "\e[31mCharging Control           : Inactive\e[0m"
                            echo "All Charging Control functions are disabled"
                            exit
                        fi
                    fi
                    
                    # Read Speed Limit Charging
                    speed_limit=$(su -c getprop lynx.fcc 2>/dev/null)
                    if [ -z "$speed_limit" ]; then
                        error_messages+="Property Charging Speed is missing!\n"
                    else
                        speed_limit_mAh=$(bc <<< "$speed_limit * 1000 / 1")
                        echo -e "\e[34mCharging Speed             : $speed_limit_mAh mAh\e[0m"
                    fi
                    
                    # Read Perf. Mode Charging Limit
                    performance_mode_speed_limit=$(su -c getprop lynx.lcc 2>/dev/null)
                    if [ -z "$performance_mode_speed_limit" ]; then
                        error_messages+="Property Perf. Mode Charging Limit is missing!\n"
                    else
                        performance_mode_speed_limit_mAh=$(bc <<< "$performance_mode_speed_limit * 1000 / 1")
                        echo -e "\e[34mPerf. Mode Charging Limit  : $performance_mode_speed_limit_mAh mAh\e[0m"
                    fi
                    
                    # Check AutoCut Charging
                    auto_cut_charging=$(su -c getprop lynx.ac 2>/dev/null)
                    if [ -z "$auto_cut_charging" ]; then
                        error_messages+="Property AutoCut Charging is missing!\n"
                    else
                        if [ "$auto_cut_charging" -eq 1 ]; then
                            echo -e "\e[32mAutoCut Charging           : Active\e[0m"
                        else
                            echo -e "\e[31mAutoCut Charging           : Inactive\e[0m"
                        fi
                    fi
                    
                    # Read Minimum Battery Percentage
                    if [ "$auto_cut_charging" -eq 1 ]; then
                        min_battery_percentage=$(su -c getprop lynx.min.ac 2>/dev/null)
                        if [ -z "$min_battery_percentage" ]; then
                            error_messages+="Property Min. Battery Percentage is missing!\n"
                        else
                            echo -e "\e[34mLower Charging Limit (%)   : $min_battery_percentage%\e[0m"
                        fi
                    fi
                    
                    # Read Maximum Battery Percentage
                    if [ "$auto_cut_charging" -eq 1 ]; then
                        max_battery_percentage=$(su -c getprop lynx.max.ac 2>/dev/null)
                        if [ -z "$max_battery_percentage" ]; then
                            error_messages+="Property Max. Battery Percentage is missing\n"
                        else
                            echo -e "\e[34mUpper Charging Limit (%)   : $max_battery_percentage%\e[0m"
                        fi
                    fi
                    
                    # Read mode file
                    mode_file="/storage/emulated/0/Lynx/mode"
                    if [ -e "$mode_file" ]; then
                        # Check Eterna
                        eterna=$(grep "^eterna=" "$mode_file" | cut -d "=" -f 2)
                        if [ -z "$eterna" ]; then
                            error_messages+="Eterna is missing!\n"
                        else
                            if [ "$eterna" -eq 1 ]; then
                                echo -e "\e[32mEterna                     : Enabled\e[0m"
                            else
                                echo -e "\e[31mEterna                     : Disabled\e[0m"
                            fi
                        fi
                        
                        # Check Flow
                        flow=$(grep "^flow=" "$mode_file" | cut -d "=" -f 2)
                        if [ -z "$flow" ]; then
                            error_messages+="Flow is missing!\n"
                        else
                            if [ "$flow" -eq 1 ]; then
                                echo -e "\e[32mFlow                       : Enabled\e[0m"
                                
                                # Check Flow Mode
                                flow_mode=$(grep "^flow_mode=" "$mode_file" | cut -d "=" -f 2)
                                if [ -z "$flow_mode" ]; then
                                    error_messages+="Flow Mode is missing\n"
                                else
                                    case "$flow_mode" in
                                        1) echo -e "\e[34mFlow Mode                  : Basic\e[0m" ;;
                                        2) echo -e "\e[34mFlow Mode                  : Advanced\e[0m" ;;
                                        3) echo -e "\e[34mFlow Mode                  : High\e[0m" ;;
                                        5) echo -e "\e[34mFlow Mode                  : Extreme\e[0m" ;;
                                        *) echo -e "\e[31mFlow Mode                  : Unknown\e[0m" ;;
                                    esac
                                fi
                            else
                                echo -e "\e[31mFlow                       : Disabled\e[0m"
                            fi
                        fi
                    else
                        error_messages+="Mode file not found!\n"
                    fi
                    
                    # Check applist_pef.txt
                    if [ ! -e "/storage/emulated/0/Lynx/applist_perf.txt" ]; then
                        error_messages+="File applist_perf.txt is missing!\n"
                    fi
                    
                    # Check applist_flow.conf
                    if [ ! -e "/storage/emulated/0/Lynx/applist_flow.conf" ]; then
                        error_messages+="File applist_flow.conf is missing!\n"
                    fi
                    
                    # missing property messages
                    if [ -n "$error_messages" ]; then
                        echo -e "\n\e[31mModule Error:\n$error_messages\e[0m"
                    fi
                else
                    echo -e "\e[31m Module not properly installed, please reinstall!\e[0m"
                    sleep 1.75
                    selected=0
                    show_menu
                fi
                echo ""
                echo "Return (backspace) | Refresh (enter)"
            elif [ $selected -eq $((num_options - 2)) ]; then
                URL="https://taplink.cc/zy0x"
                function show_progress() {
                    local msg="Redirecting"
                    local i=0
                    while true; do
                        printf "\r%s%s" "$msg" "$dots"
                        sleep 1
                        dots+="."
                        let i+=1
                        if [ $i -eq 4 ]; then
                            break
                        fi
                    done
                }
                show_progress &
                sleep 3
                kill -SIGTERM $progress_pid >/dev/null 2>&1
                am start -a android.intent.action.VIEW -d "$URL" > /dev/null
                sleep 1.25
                clear
                pkill -9 termux && break
            elif [ $selected -eq $((num_options - 1)) ]; then
                echo -e "\033[31mExit Lynx!\033[0m"
                sleep 1.25
                clear
                pkill -9 termux && break || exit
            else
                echo "COMMING SOON!"
                sleep 1.5
                clear
                show_menu
            fi
            ;;
    esac
done