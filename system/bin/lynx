# Fungsi Current Settings
show_info() {
    MODPROP="/data/adb/modules/Lynx/module.prop"
    name=$(grep '^name=' "$MODPROP" | sed 's/^name=\(.*\) -.*/\1/')
    codename=$(grep '^name=' "$MODPROP" | awk -F'=' '{print $2}' | awk '{print $3}')
    owner=$(grep '^author=' "$MODPROP" | cut -d'=' -f2)
    version=$(grep '^version=' "$MODPROP" | cut -d'=' -f2)
    versionCode=$(grep '^versionCode=' "$MODPROP" | cut -d'=' -f2)
    date=$(echo "$versionCode" | sed 's/\(....\)\(..\)\(..\)/\3-\2-\1/')
    clear
    echo -e "\033[1;30;94m 𝙲𝚛𝚎𝚍𝚒𝚝: 𝙽𝚘𝚒𝚛 \033[0m"
    echo ""
    echo "--------------------------"
    echo -e "\033[33m\"        Lynx Info       \"\033[0m"
    echo "--------------------------"
    echo ""
    echo " • Name            : $name "
    echo " • Codename        : $codename "
    echo " • Version         : $version "
    echo " • Owner           : $owner "
    echo " • Release Date    : $date "
    echo " "
    echo " Device info:"
    echo " • Brand           : $(getprop ro.product.system.brand) "
    echo " • Device          : $(getprop ro.product.system.model) "
    echo " • Processor       : $(getprop ro.product.board) "
    echo " • Android Version : $(getprop ro.system.build.version.release) "
    echo " • SDK Version     : $(getprop ro.build.version.sdk) "
    echo " • Architecture    : $(getprop ro.product.cpu.abi) "
    echo " • Kernel Version  : $(uname -r) "
    echo ""
}

