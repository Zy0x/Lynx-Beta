# Menampilkan menu awal
show_menu

# Membaca input dari pengguna
while true; do
    read -rsn1 input

    case $input in
        A) # Panah atas
            if [ $selected -gt 0 ]; then
                selected=$((selected - 1))
            else
                selected=$((num_options - 1))
            fi
            show_menu
            ;;
        B) # Panah bawah
            if [ $selected -lt $((num_options - 1)) ]; then
                selected=$((selected + 1))
            else
                selected=0
            fi
            show_menu
            ;;
        C) # Panah Kanan
            if [ $selected -lt $((num_options - 1)) ]; then
                selected=$((selected + 1))
            else
                selected=0
            fi
            show_menu
            ;;
        D) # Panah Kiri
            if [ $selected -gt 0 ]; then
                selected=$((selected - 1))
            else
                selected=$((num_options - 1))
            fi
            show_menu
            ;;
        H) # Tombol Home
            selected=0
            show_menu
            ;;
        F) # Tombol End
            echo -e "\033[1A" # Pindah ke baris sebelumnya
            echo -e "\033[K"  # Hapus seluruh baris
            echo -e "\033[31mExit Lynx!\033[0m"
            sleep 1.25
            clear
            pkill -9 termux && break || exit
            ;;
        $'\x7f') # Tombol backspace (hapus)
            if [ $selected -eq 0 ]; then
                echo -e "\033[1A" # Pindah ke baris sebelumnya
                echo -e "\033[K"  # Hapus seluruh baris
                echo -e "\033[31mExit Lynx!\033[0m"
                sleep 1.25
                clear
                exit
            else
                selected=0
                show_menu
            fi
            ;;
        "") # Enter
            if [ $selected -eq 0 ]; then
                show_cc_menu
                # Membaca input untuk submenu Charging Control
                while true; do
                    read -rsn1 cc_input
                    case $cc_input in
                        A) # Panah atas
                            if [ $cc_selected -gt 0 ]; then
                                cc_selected=$((cc_selected - 1))
                            else
                                cc_selected=$((num_cc_options - 1))
                            fi
                            show_cc_menu
                            ;;
                        B) # Panah bawah
                            if [ $cc_selected -lt $((num_cc_options - 1)) ]; then
                                cc_selected=$((cc_selected + 1))
                            else
                                cc_selected=0
                            fi
                            show_cc_menu
                            ;;
                        C) # Panah Kanan
                            if [ $cc_selected -lt $((num_cc_options - 1)) ]; then
                                cc_selected=$((cc_selected + 1))
                            else
                                cc_selected=0
                            fi
                            show_cc_menu
                            ;;
                        D) # Panah Kiri
                            if [ $cc_selected -gt 0 ]; then
                                cc_selected=$((cc_selected - 1))
                            else
                                cc_selected=$((num_cc_options - 1))
                            fi
                            show_cc_menu
                            ;;
                        H) # Tombol Home
                            cc_selected=0
                            selected=0
                            show_menu
                            break
                            ;;
                        F) # Tombol End
                            echo -e "\033[1A" # Pindah ke baris sebelumnya
                            echo -e "\033[K"  # Hapus seluruh baris
                            echo -e "\033[31mExit Lynx!\033[0m"
                            sleep 1.25
                            clear
                            exit
                            ;;
                        $'\x7f') # Tombol backspace (hapus)
                            if [ $cc_selected -eq 0 ]; then
                                show_menu
                                break
                            else
                                cc_selected=0
                                show_cc_menu
                            fi
                            ;;
                        "") # Enter
                            if [ $cc_selected -eq 0 ]; then
                                setprop lynx.cc 1
                                sed -i 's/lynx.cc=.*/lynx.cc=1/' /data/adb/modules/lynx/system.prop
                                echo -e "\e[32mCharging Control Enabled\e[0m"
                                sleep 1.25
                                cc_selected=0
                                clear
                                show_cc_menu
                            elif [ $cc_selected -eq 1 ]; then
                                setprop lynx.cc 0
                                sed -i 's/lynx.cc=.*/lynx.cc=0/' /data/adb/modules/lynx/system.prop
                                echo -e "\e[32mCharging Control Disabled\e[0m"
                                sleep 1.25
                                cc_selected=0
                                clear
                                show_cc_menu
                            elif [ $cc_selected -eq 2 ]; then
                                echo ""
                                echo " Example: "
                                echo " for 2400mA, write 2.4"
                                echo -ne "\e[36mInput Value: \e[0m"
                                read input
                                if echo "$input" | grep -E -q '^[0-9]+(\.[0-9]+)?$'; then
                                    result=$(echo "$input * 1000" | bc)
                                    result=$(echo $result | sed 's/\.0*$//')
                                    setprop lynx.fcc $input
                                    sed -i "s/lynx.fcc=.*/lynx.fcc=$input/" /data/adb/modules/lynx/system.prop
                                    echo -e "\e[32mSet to $result mA\e[0m"
                                    sleep 1.25
                                    cc_selected=0
                                    clear
                                    show_cc_menu
                                else
                                    echo -e '\e[31mInvalid input. Enter a decimal or whole number!\e[0m'
                                    sleep 1.25
                                    cc_selected=0
                                    clear
                                    show_cc_menu
                                fi
                            elif [ $cc_selected -eq 3 ]; then
                                echo ""
                                echo " Example: "
                                echo " for 1600mA, write 1.6"
                                echo -ne "\e[36mInput Value: \e[0m"
                                read input
                                if echo "$input" | grep -E -q '^[0-9]+(\.[0-9]+)?$'; then
                                    result=$(echo "$input * 1000" | bc)
                                    result=$(echo $result | sed 's/\.0*$//')
                                    setprop lynx.lcc $input
                                    sed -i "s/lynx.lcc=.*/lynx.lcc=$input/" /data/adb/modules/lynx/system.prop
                                    echo -e "\e[32mSet to $result mA\e[0m"
                                    sleep 1.25
                                    cc_selected=0
                                    clear
                                    show_cc_menu
                                else
                                    echo -e '\e[31mInvalid input. Enter a decimal or whole number!\e[0m'
                                    sleep 1.75
                                    cc_selected=0
                                    clear
                                    show_cc_menu
                                fi
                            elif [ $cc_selected -eq 4 ]; then
                                clear
                                show_ac_menu
                                # Membaca input untuk submenu AutoCut Charging
                                while true; do
                                read -rsn1 ac_input
                                case $ac_input in
                                    A) # Panah atas
                                        if [ $ac_selected -gt 0 ]; then
                                            ac_selected=$((ac_selected - 1))
                                        else
                                            ac_selected=$((num_ac_options - 1))
                                        fi
                                        show_ac_menu
                                        ;;
                                    B) # Panah bawah
                                        if [ $ac_selected -lt $((num_ac_options - 1)) ]; then
                                            ac_selected=$((ac_selected + 1))
                                        else
                                            ac_selected=0
                                        fi
                                        show_ac_menu
                                        ;;
                                    C) # Panah Kanan
                                        if [ $ac_selected -lt $((num_ac_options - 1)) ]; then
                                            ac_selected=$((ac_selected + 1))
                                        else
                                            ac_selected=0
                                        fi
                                        show_ac_menu
                                        ;;
