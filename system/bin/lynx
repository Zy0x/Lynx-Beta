                                            break
                                        else
                                            echo "Invalid input. Please enter 'yes' or 'no'."
                                            sleep 1.5
                                            printf "\033[A\033[K\033[A\033[K"
                                        fi
                                    done
                                else
                                    echo -e "\e[31mFile can't read or not found!\e[0m"
