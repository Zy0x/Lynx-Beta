                                        if [ -n "$matches" ]; then
                                            sed -i "$(echo "${matches}" | sed 's/$/d/' | tr '\n' ',' | sed 's/,$//')" "$file"
                                            echo -e "\e[32m  $input removed successfully!\e[0m"
                                            sleep 1.25
                                            clear
                                            perf_selected=0
                                            show_perf_menu
                                        else
                                            echo -e "\e[31m  No matches for '$input'\e[0m"
                                            sleep 1.5
                                            clear
                                            perf_selected=0
                                            show_perf_menu
                                        fi
                                    fi
                                else
                                    echo -e "\e[31mFile can't read or not found!\e[0m"
                                    echo -e "\e[31mPlease reinstall module or directly add the application.\e[0m"
                                    sleep 2
                                    perf_selected=0
                                    selected=0
                                    show_menu
                                    break
                                fi
                            elif [ $perf_selected -eq $((num_perf_options - 1)) ]; then
                                selected=0
                                perf_selected=0
                                show_menu
                                break
                            fi
