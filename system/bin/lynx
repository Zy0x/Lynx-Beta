#!/bin/sh

# ==========================================
# Lynx Modern CLI - POSIX & Termux Compatible
# ==========================================

# --- Configuration & Globals ---
MODPATH="/data/adb/modules/Lynx"
LXCORE="/system/bin/Lxcore"
PROP_FILE="$MODPATH/system.prop"
LOG_FILE="/storage/emulated/0/Lynx/Lynx.log"

# Colors (POSIX-friendly escape sequences)
C_CYAN="\033[96m"
C_RED="\033[91m"
C_GREEN="\033[32m"
C_YELLOW="\033[33m"
C_PURPLE="\033[35m"
C_BLUE="\033[34m"
C_RESET="\033[0m"
C_DIM="\033[2m"
C_BOLD="\033[1m"

# State
CURRENT_MENU="main"
SELECTED_INDEX=0

# --- Utility Functions ---

log_msg() {
    local msg="[$(date '+%Y-%m-%d %H:%M:%S')] $1"
    echo "$msg" >> "$LOG_FILE" 2>/dev/null
}

print_header() {
    clear
    printf "${C_BOLD}${C_BLUE} 𝙲𝚛𝚎𝚍𝚒𝚝: 𝙽𝚘𝚒𝚛 ${C_RESET}\n\n"
    printf "----------------------------------\n"
    printf "${C_YELLOW}\"           %s           \"${C_RESET}\n" "$1"
    printf "----------------------------------\n"
    printf " ${C_DIM}${C_CYAN}(↑↓←→) ${C_RED}| ${C_CYAN}(↵) ${C_RED}| ${C_CYAN}BKSP ${C_RED}| ${C_CYAN}END ${C_RED}| ${C_CYAN}HOME${C_RESET}\n\n"
}

show_message() {
    local color="$1"
    local msg="$2"
    local delay="${3:-1.25}"
    printf "${color}${msg}${C_RESET}\n"
    sleep "$delay"
}

set_prop_val() {
    local key="$1"
    local val="$2"
    setprop "$key" "$val" 2>/dev/null
    if [ -f "$PROP_FILE" ]; then
        sed -i "s/$key=.*/$key=$val/" "$PROP_FILE"
    fi
}

# --- Menu Data (POSIX-compliant strings instead of arrays) ---

# Format: "Option 1|Option 2|Option 3"
MENU_MAIN_OPTS="Charging Control|Flow|Eterna|List App Performance|List App Flow & Eterna|Misc|Current Settings|Support|Exit"
MENU_CC_OPTS="Enable|Disable|Set Value|Set Limit (in Perf.)|AutoCut Charging|Return"
MENU_AC_OPTS="Enable|Disable|Set Min|Set Max|Return"
MENU_FLOW_OPTS="Enable|Disable|Flow Mode|Return"
MENU_FM_OPTS="Basic|Advance|High|Extreme|Return"
MENU_ETERNA_OPTS="Enable|Disable|Return"
MENU_PERF_OPTS="Current Active App|Add an App|Delete App|Return"
MENU_FLET_OPTS="Current Active App|Add an App|Delete App|Return"
MENU_MISC_OPTS="GPU Cache Cleaner|Google Logout Fixer|Tweak Genshin Impact|Clear Ram (Experimental)|DexOptimization|Return"
MENU_GI_OPTS="OpenGL|Vulkan|Return"

# Helper to get option by index from pipe-separated string
get_opt() {
    local list="$1"
    local idx="$2"
    # Use cut to get the (idx+1)-th field
    echo "$list" | cut -d'|' -f$((idx + 1))
}

# Helper to get count of options
get_count() {
    local list="$1"
    # Count pipes and add 1
    local count=$(echo "$list" | grep -o '|' | wc -l)
    echo $((count + 1))
}

# --- Core Logic ---

draw_menu() {
    local title="$1"
    local opts_list="$2"
    local num_opts=$(get_count "$opts_list")
    
    print_header "$title"
    
    local i=0
    while [ $i -lt $num_opts ]; do
        local opt=$(get_opt "$opts_list" $i)
        if [ $i -eq $SELECTED_INDEX ]; then
            printf "-> ${C_PURPLE}%s${C_RESET}\n" "$opt"
        else
            if [ $((i + 1)) -eq $num_opts ] || [ "$opt" = "Return" ] || [ "$opt" = "Exit" ]; then
                printf "   ${C_YELLOW}%s${C_RESET}\n" "$opt"
            elif [ $((i + 2)) -eq $num_opts ] && [ "$title" = "Lynx Option" ]; then
                printf "\n   ${C_BLUE}%s${C_RESET}\n" "$opt"
            else
                printf "   %s\n" "$opt"
            fi
        fi
        i=$((i + 1))
    done
}

read_key() {
    # POSIX-compliant key reading using stty
    local key
    stty -echo -icanon time 0 min 1
    key=$(dd bs=3 count=1 2>/dev/null)
    stty echo icanon
    
    case "$key" in
        $'\x1b[A') echo "UP" ;;
        $'\x1b[B') echo "DOWN" ;;
        $'\x1b[C') echo "RIGHT" ;;
        $'\x1b[D') echo "LEFT" ;;
        $'\x1b[H'|$'\x1bOH') echo "HOME" ;;
        $'\x1b[F'|$'\x1bOF') echo "END" ;;
        "") echo "ENTER" ;;
        $'\x7f'|$'\x08') echo "BACKSPACE" ;;
        *) echo "UNKNOWN" ;;
    esac
}

# --- Action Handlers ---

handle_cc() {
    case "$1" in
        0) set_prop_val "lynx.cc" 1; show_message "$C_GREEN" "Charging Control Enabled" ;;
        1) set_prop_val "lynx.cc" 0; show_message "$C_GREEN" "Charging Control Disabled" ;;
        2) 
            printf "\n${C_CYAN}Input Value (e.g., 2.4 for 2400mA): ${C_RESET}"
            read input
            if echo "$input" | grep -E -q '^[0-9]+(\.[0-9]+)?$'; then
                set_prop_val "lynx.fcc" "$input"
                local ma=$(echo "$input * 1000" | bc 2>/dev/null | sed 's/\.0*$//')
                show_message "$C_GREEN" "Set to ${ma:-unknown} mA"
            else
                show_message "$C_RED" "Invalid input!"
            fi
            ;;
        3)
            printf "\n${C_CYAN}Input Limit (e.g., 1.6 for 1600mA): ${C_RESET}"
            read input
            if echo "$input" | grep -E -q '^[0-9]+(\.[0-9]+)?$'; then
                set_prop_val "lynx.lcc" "$input"
                local ma=$(echo "$input * 1000" | bc 2>/dev/null | sed 's/\.0*$//')
                show_message "$C_GREEN" "Set to ${ma:-unknown} mA"
            else
                show_message "$C_RED" "Invalid input!"
            fi
            ;;
        4) CURRENT_MENU="ac"; SELECTED_INDEX=0 ;;
        5) CURRENT_MENU="main"; SELECTED_INDEX=0 ;;
    esac
}

handle_ac() {
    case "$1" in
        0) set_prop_val "lynx.ac" 1; show_message "$C_GREEN" "AutoCut Enabled" ;;
        1) set_prop_val "lynx.ac" 0; show_message "$C_GREEN" "AutoCut Disabled" ;;
        2)
            printf "\n${C_CYAN}Input Min %%: ${C_RESET}"
            read input
            if echo "$input" | grep -q '^[0-9]\+$'; then
                set_prop_val "lynx.min" "$input"
                show_message "$C_GREEN" "Min set to $input%"
            else
                show_message "$C_RED" "Invalid input!"
            fi
            ;;
        3)
            printf "\n${C_CYAN}Input Max %%: ${C_RESET}"
            read input
            if echo "$input" | grep -q '^[0-9]\+$'; then
                set_prop_val "lynx.max" "$input"
                show_message "$C_GREEN" "Max set to $input%"
            else
                show_message "$C_RED" "Invalid input!"
            fi
            ;;
        4) CURRENT_MENU="cc"; SELECTED_INDEX=4 ;;
    esac
}

handle_flow() {
    case "$1" in
        0) set_prop_val "lynx.flow" 1; show_message "$C_GREEN" "Flow Enabled" ;;
        1) set_prop_val "lynx.flow" 0; show_message "$C_GREEN" "Flow Disabled" ;;
        2) CURRENT_MENU="fm"; SELECTED_INDEX=0 ;;
        3) CURRENT_MENU="main"; SELECTED_INDEX=1 ;;
    esac
}

handle_fm() {
    if [ "$1" -eq 4 ]; then
        CURRENT_MENU="flow"; SELECTED_INDEX=2
        return
    fi
    local mode=""
    case "$1" in
        0) mode="basic" ;;
        1) mode="advance" ;;
        2) mode="high" ;;
        3) mode="extreme" ;;
    esac
    set_prop_val "lynx.fm" "$mode"
    show_message "$C_GREEN" "Flow Mode set to $mode"
}

handle_eterna() {
    case "$1" in
        0) set_prop_val "lynx.eterna" 1; show_message "$C_GREEN" "Eterna Enabled" ;;
        1) set_prop_val "lynx.eterna" 0; show_message "$C_GREEN" "Eterna Disabled" ;;
        2) CURRENT_MENU="main"; SELECTED_INDEX=2 ;;
    esac
}

handle_perf() {
    case "$1" in
        0) 
            local app=$(getprop lynx.perf.app 2>/dev/null)
            show_message "$C_CYAN" "Current Active App: ${app:-None}" 2
            ;;
        1)
            printf "\n${C_CYAN}Enter Package Name: ${C_RESET}"
            read pkg
            if [ -n "$pkg" ]; then
                echo "$pkg" >> "$MODPATH/script/applist_perf.txt"
                show_message "$C_GREEN" "Added $pkg"
            fi
            ;;
        2)
            printf "\n${C_CYAN}Enter Package Name to Delete: ${C_RESET}"
            read pkg
            if [ -n "$pkg" ]; then
                sed -i "/$pkg/d" "$MODPATH/script/applist_perf.txt"
                show_message "$C_GREEN" "Deleted $pkg"
            fi
            ;;
        3) CURRENT_MENU="main"; SELECTED_INDEX=3 ;;
    esac
}

handle_flet() {
    case "$1" in
        0) 
            local app=$(getprop lynx.flet.app 2>/dev/null)
            show_message "$C_CYAN" "Current Active App: ${app:-None}" 2
            ;;
        1)
            printf "\n${C_CYAN}Enter Package Name: ${C_RESET}"
            read pkg
            if [ -n "$pkg" ]; then
                echo "$pkg" >> "$MODPATH/script/flow/extra.conf"
                show_message "$C_GREEN" "Added $pkg"
            fi
            ;;
        2)
            printf "\n${C_CYAN}Enter Package Name to Delete: ${C_RESET}"
            read pkg
            if [ -n "$pkg" ]; then
                sed -i "/$pkg/d" "$MODPATH/script/flow/extra.conf"
                show_message "$C_GREEN" "Deleted $pkg"
            fi
            ;;
        3) CURRENT_MENU="main"; SELECTED_INDEX=4 ;;
    esac
}

handle_misc() {
    case "$1" in
        0) sh "$MODPATH/script/misc/gpu_cache_cleaner.sh"; show_message "$C_GREEN" "GPU Cache Cleaned" ;;
        1) sh "$MODPATH/script/misc/g_fixer.sh"; show_message "$C_GREEN" "Google Logout Fixed" ;;
        2) CURRENT_MENU="gi"; SELECTED_INDEX=0 ;;
        3) $LXCORE -ram apply; show_message "$C_GREEN" "RAM Cleared via Lxcore" ;;
        4) sh "$MODPATH/script/misc/Dexoptimizer.sh"; show_message "$C_GREEN" "DexOptimization Started" ;;
        5) CURRENT_MENU="main"; SELECTED_INDEX=5 ;;
    esac
}

handle_gi() {
    case "$1" in
        0) sh "$MODPATH/script/misc/GI_GL.sh"; show_message "$C_GREEN" "Genshin Impact set to OpenGL" ;;
        1) sh "$MODPATH/script/misc/GI_VK.sh"; show_message "$C_GREEN" "Genshin Impact set to Vulkan" ;;
        2) CURRENT_MENU="misc"; SELECTED_INDEX=2 ;;
    esac
}

# --- Main Loop ---

while true; do
    local opts=""
    case "$CURRENT_MENU" in
        "main") opts="$MENU_MAIN_OPTS"; draw_menu "Lynx Option" "$opts" ;;
        "cc")   opts="$MENU_CC_OPTS"; draw_menu "Charging Control" "$opts" ;;
        "ac")   opts="$MENU_AC_OPTS"; draw_menu "Auto Cut Charging" "$opts" ;;
        "flow") opts="$MENU_FLOW_OPTS"; draw_menu "Flow" "$opts" ;;
        "fm")   opts="$MENU_FM_OPTS"; draw_menu "Flow Mode" "$opts" ;;
        "eterna") opts="$MENU_ETERNA_OPTS"; draw_menu "Eterna" "$opts" ;;
        "perf") opts="$MENU_PERF_OPTS"; draw_menu "List App Performance" "$opts" ;;
        "flet") opts="$MENU_FLET_OPTS"; draw_menu "List App Flow & Eterna" "$opts" ;;
        "misc") opts="$MENU_MISC_OPTS"; draw_menu "Misc" "$opts" ;;
        "gi")   opts="$MENU_GI_OPTS"; draw_menu "Tweak Genshin Impact" "$opts" ;;
    esac
    
    local key=$(read_key)
    local num_opts=$(get_count "$opts")

    case "$key" in
        "UP")    SELECTED_INDEX=$(( (SELECTED_INDEX - 1 + num_opts) % num_opts )) ;;
        "DOWN")  SELECTED_INDEX=$(( (SELECTED_INDEX + 1) % num_opts )) ;;
        "LEFT"|"BACKSPACE")
            case "$CURRENT_MENU" in
                "main") exit 0 ;;
                "cc"|"flow"|"eterna"|"perf"|"flet"|"misc") CURRENT_MENU="main"; SELECTED_INDEX=0 ;;
                "ac") CURRENT_MENU="cc"; SELECTED_INDEX=4 ;;
                "fm") CURRENT_MENU="flow"; SELECTED_INDEX=2 ;;
                "gi") CURRENT_MENU="misc"; SELECTED_INDEX=2 ;;
            esac
            ;;
        "HOME") SELECTED_INDEX=0 ;;
        "END")  SELECTED_INDEX=$((num_opts - 1)) ;;
        "ENTER")
            case "$CURRENT_MENU" in
                "main")
                    case "$SELECTED_INDEX" in
                        0) CURRENT_MENU="cc"; SELECTED_INDEX=0 ;;
                        1) CURRENT_MENU="flow"; SELECTED_INDEX=0 ;;
                        2) CURRENT_MENU="eterna"; SELECTED_INDEX=0 ;;
                        3) CURRENT_MENU="perf"; SELECTED_INDEX=0 ;;
                        4) CURRENT_MENU="flet"; SELECTED_INDEX=0 ;;
                        5) CURRENT_MENU="misc"; SELECTED_INDEX=0 ;;
                        6) $LXCORE -help; printf "\nPress Enter to return..."; read dummy ;;
                        7) [ -f "$MODPATH/credit.md" ] && cat "$MODPATH/credit.md"; printf "\nPress Enter to return..."; read dummy ;;
                        8) exit 0 ;;
                    esac
                    ;;
                "cc")    handle_cc "$SELECTED_INDEX" ;;
                "ac")    handle_ac "$SELECTED_INDEX" ;;
                "flow")  handle_flow "$SELECTED_INDEX" ;;
                "fm")    handle_fm "$SELECTED_INDEX" ;;
                "eterna") handle_eterna "$SELECTED_INDEX" ;;
                "perf")  handle_perf "$SELECTED_INDEX" ;;
                "flet")  handle_flet "$SELECTED_INDEX" ;;
                "misc")  handle_misc "$SELECTED_INDEX" ;;
                "gi")    handle_gi "$SELECTED_INDEX" ;;
            esac
            ;;
    esac
done
