# Break Menu
stop_menu_flow=false

# UI Color
BRIGHT_CYAN="\e[96m"
BRIGHT_RED="\e[91m"
RESET="\e[0m"
DIM="\e[2m"

# MAIN MENU
## TINGKAT PERTAMA
## Opsi Menu
options=("Charging Control" "Flow" "Eterna" "List App Performance" "List App Flow & Eterna" "Misc" "Current Settings" "Support" "Exit")
num_options=${#options[@]}
selected=0
## Charging Control 
charging_control_options=("Enable" "Disable" "Set Value" "Set Limit (in Perf.)" "AutoCut Charging" "Return")
num_cc_options=${#charging_control_options[@]}
cc_selected=0
## Flow 
flow_options=("Enable" "Disable" "Flow Mode" "Return")
num_flow_options=${#flow_options[@]}
flow_selected=0
## Eterna 
eterna_options=("Enable" "Disable" "Return")
num_eterna_options=${#eterna_options[@]}
eterna_selected=0
## List App Performance
perf_options=("Current Active App " "Add an App" "Delete App" "Return")
num_perf_options=${#perf_options[@]}
perf_selected=0
## List App Flow dan Eterna 
flet_options=("Current Active App " "Add an App" "Delete App" "Return")
num_flet_options=${#flet_options[@]}
flet_selected=0

### TINGKAT KEDUA
### Charging Control 
autocut_options=("Enable" "Disable" "Set Min" "Set Max" "Return")
num_ac_options=${#autocut_options[@]}
ac_selected=0
### Flow Mode
fm_options=("Basic" "Advance" "High" "Extreme" "Return")
num_fm_options=${#fm_options[@]}
fm_selected=0
### Misc
misc_options=("GPU Cache Cleaner" "Google Logout Fixer" "Tweak Genshin Impact" "Clear Ram (Experiental)" "DexOptimization" "Return" )
num_misc_options=${#misc_options[@]}
misc_selected=0
### GI
gi_options=("OpenGL" "Vulkan" "Return")
num_gi_options=${#gi_options[@]}
gi_selected=0

# Fungsi menu
show_menu() {
    clear
    echo -e "\033[1;30;94m 𝙲𝚛𝚎𝚍𝚒𝚝: 𝙽𝚘𝚒𝚛 \033[0m"
    echo ""
    echo "----------------------------------"
    echo -e "\033[33m\"           Lynx Option          \"\033[0m"
    echo "----------------------------------"
    echo -e " ${DIM}${BRIGHT_CYAN}(↑↓←→) ${BRIGHT_RED}| ${BRIGHT_CYAN}(↵) ${BRIGHT_RED}| ${BRIGHT_CYAN}BKSP ${BRIGHT_RED}| ${BRIGHT_CYAN}END ${BRIGHT_RED}| ${BRIGHT_CYAN}HOME${RESET}"
    echo ""
    i=0
    while [ $i -lt $num_options ]; do
        if [ $i -eq $selected ]; then
            if [ "$i" -eq $(($num_options - 1)) ]; then
                echo -e "\e[0;35m ${options[i]}\e[0m"  # Jika dipilih, warna ungu untuk opsi terakhir
            elif [ "$i" -eq $(($num_options - 2)) ]; then
                echo -e "\n\e[0;35m ${options[i]}\e[0m"  # Jika dipilih, warna biru gelap untuk opsi kedua dari terakhir
            else
                echo -e "-> \e[0;35m${options[i]}\e[0m"  # Jika dipilih, warna ungu
            fi
        elif [ $i -eq $(($num_options - 1)) ]; then
            echo -e "\e[0;33m ${options[i]}\e[0m"      # Jika opsi terakhir dan tidak dipilih, warna kuning
        elif [ $i -eq $(($num_options - 2)) ]; then
            echo -e "\n\e[0;34m ${options[i]}\e[0m" # Jika opsi kedua dari terakhir dan tidak dipilih, warna biru gelap
        else
            echo "   ${options[i]}"
        fi
        i=$((i + 1))
    done
    
}

# Fungsi Charging Control
show_cc_menu() {
    clear
    echo -e "\033[1;30;94m 𝙲𝚛𝚎𝚍𝚒𝚝: 𝙽𝚘𝚒𝚛 \033[0m"
    echo ""
    echo "----------------------------------"
    echo -e "\033[33m\"        Charging Control        \"\033[0m"
    echo "----------------------------------"
    echo -e " ${DIM}${BRIGHT_CYAN}(↑↓←→) ${BRIGHT_RED}| ${BRIGHT_CYAN}(↵) ${BRIGHT_RED}| ${BRIGHT_CYAN}BKSP ${BRIGHT_RED}| ${BRIGHT_CYAN}END ${BRIGHT_RED}| ${BRIGHT_CYAN}HOME${RESET}"
    echo ""
    echo ""
    i=0
    while [ $i -lt $num_cc_options ]; do
        if [ $i -eq $cc_selected ]; then
            if [ "$i" -eq "$(($num_cc_options - 1))" ]; then
                echo -e "-> \e[0;35m${charging_control_options[i]}\e[0m"
            else
                echo "-> \e[0;35m${charging_control_options[i]}\e[0m"
            fi
        else
            if [ "$i" -eq "$(($num_cc_options - 1))" ]; then
                echo -e "   \e[0;33m${charging_control_options[i]}\e[0m"
            else
                echo "   ${charging_control_options[i]}"
            fi
        fi
        i=$((i + 1))
    done
}

